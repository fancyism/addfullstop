# AddFullStop — Environment Variables
# Copy this file to .env.local and fill in your values

# OpenRouter API Key (required for AI-powered features)
# Get your key at https://openrouter.ai/keys
# When set, features use AI for better results. When unset, heuristic fallbacks are used.
OPENROUTER_API_KEY=

# Optional: Your site URL (used in OpenRouter API headers for ranking)
NEXT_PUBLIC_SITE_URL=https://addfullstop.app
